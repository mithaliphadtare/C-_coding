#include<iostream>
using namespace std;
class parent{
protected:
float bal;
int change;
public:
parent(){

bal=10000;
}
void show(){

cout<<bal<<endl;
}

protected:
void update(){
bal=change;
cout<<"balance:"<<bal<<endl;
}

};

class child:public parent{
public:

void deposit(int amt1){
if(amt1>0){
change=bal+amt1;
update();
}
else{
cout<<"Invalid"<<endl;
}
}

void withdraw(int amt2){
if(amt2>0 && amt2<=bal){
change=bal-amt2;
update();
}
else{
cout<<"invalid";
}
}
};

int main(){

parent pobj;
child cobj;
cobj.show();

cobj.deposit(-2000);
cobj.withdraw(15000);

return 0;
}
